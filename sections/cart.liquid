{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}
 {% stylesheet %}
   .cart_page a{max-width: 150px;}
   .cart_page td{border: 2px solid black ;}
   code{color:forestgreen;font-size: 20px;font-weight: 600;}

 {% endstylesheet %}
 

<h1>{{ 'cart.title' | t }}</h1>

<form class="cart_page" action="{{ routes.cart_url }}" method="post">
  <table>
    {{cart.product.title | json}}
    {% for item in cart.items %}
      <tr>
        <td>
          {% render 'image', image: item.image, url: item.url %}
        </td>
        <td>
        <code>[item.product.title] </code>
          <p>{{ item.product.title }}</p>
          {{ 'cart.remove' | t | link_to: item.url_to_remove }}
        </td>
        <td>
        <code>[item.title] </code>
          <p>{{ item.title }}</p>
          {{ 'cart.remove' | t | link_to: item.url_to_remove }}
        </td>
        <td>
        <code>[item.price] </code>
          <p>{{ item.price }}</p>
          {{ 'cart.remove' | t | link_to: item.url_to_remove }}
        </td>
           <td>
        <code>[item.product.price] </code>
          <p>{{ item.product.price }}</p>
        </td>
        <td>
          <input type="text" name="updates[]" value="{{ item.quantity }}">
          <input type="submit" value="{{ 'cart.update' | t }}">
        </td>
      </tr>
    {% endfor %}
  </table>
<table>

    <tr>

    <td>
    <code>[cart.item_count] </code>
    <p>{{ cart.item_count }}</p>

    </td>

    <td>
    <code>[cart.total_discount]</code>
    <p>{{ cart.total_discount | money }}</p>
    </td>

    <td>
    <code>[cart.original_total_price]</code>
    <p>{{ cart.original_total_price | money }}</p>
    </td>

    <td>
    <code>[cart.total_weight]</code>
    <p>{{ cart.total_weight | weight_with_unit }}</p>
    </td>

    <td>
    <code>[cart.currency]</code>
    <p>{{ cart.currency }}</p>
    </td>

    <td>
    <code>[cart.note]</code>
    <p>{{ cart.note }}</p>
    </td>

    <td>
    <code>[cart.attributes['gift_wrap']]</code>
    <p>{{ cart.attributes['gift_wrap'] }}</p>
    </td>

    <td>
    <code>[cart.discount_codes]</code>

    {% for discount in cart.discount_codes %}
    <p>
    Code: {{ discount.code }} <br>
    Amount: {{ discount.amount | money }}
    </p>
    {% endfor %}
    </td>

    <td>
    <code>[cart.taxes_included]</code>

    {% if cart.taxes_included %}
    <p>Taxes Included</p>
    {% else %}
    <p>Taxes Not Included</p>
    {% endif %}
    </td>

    <td>
    <code>[cart.requires_shipping]</code>

    {% if cart.requires_shipping %}
    <p>Shipping Required</p>
    {% else %}
    <p>No Shipping Required</p>
    {% endif %}
    </td>


    </tr>

  </table>
  <input type="submit" name="checkout" value="{{ 'cart.checkout' | t }}">
</form>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
