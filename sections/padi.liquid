
<button id="cart-btn">
  Get Cart
</button>
<button id="add-cart">
  Add Product
</button>
<script>
let btn=document.getElementById("cart-btn");
btn.addEventListener("click",()=>{

    fetch("/cart.js")
    .then(respone =>{
    console.log("respone received");
   return respone.json()
    } )
    .then(data =>{
        console.log(data);
        console.log(data.item_count)
    })
    .catch(error =>{
    console.error(error)})

})

let addCart=document.getElementById("add-cart");
addCart.addEventListener("click",()=>{
    console.log("button clicked")


})





</script>









</script>
{% schema %}
{
  "name": "Practice",
  "settings": [
    {
      "type": "select",
      "id": "grid_item_width",
      "label": "t:labels.grid_item_width",
      "options": [
        { "value": "collections--compact", "label": "t:options.size.small" },
        { "value": "collections--full", "label": "t:options.size.large" }
      ],
      "default": "collections--full"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "t:labels.grid_gap",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 10
    }
  ],
  "presets": [{ "name": "Practice" }]
}


{% endschema %}