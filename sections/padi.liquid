<button class="cart btn btn-primary">Get Cart Item</button>
<button class="addCart btn btn-primary">Get Cart Item</button>





{% javascript %}
console.log("script loaded");
let cartData = document.querySelector(".cart")
cartData.addEventListener("click",()=>{
console.log("butn loaded")

fetch("/cart.js")
.then(response=>{return response.json()})
.then(data=> {
  console.log(data);
  // console.log(data.item_count);
  // console.log(data.total_price);
  // console.log(data.items[0].product_title);
  // console.log(data.items)
  let total = 0;
  let lineItem=0
  let title
let  mostExpensive;
  data.items.forEach(element => {
    total =total+element.quantity;
    if (element.line_price > lineItem) {
      
      lineItem =element.line_price;
      title= element.product_title
      mostExpensive = element;
    }
  })
  console.log(`The total is ${total}`)
  console.log(lineItem);
  console.log(`Most expensive ${title} - ${lineItem}`)
  console.log(mostExpensive)
  });
})

let add=document.querySelector(".addCart")
add.addEventListener("click",()=>{
fetch("/cart/add.js",{
  method:"POST",
  headers:{"Content-Type":"application/json"},
  body:JSON.stringify({
    id:1,
    quantity:2
  })
})
  .then(response=> response.json())
  .then(data=>console.log(data))
  .catch(error=>console.error(error);
  )


})
  
{% endjavascript %}









